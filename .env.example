# ─────────────────────────────────────────────────────
# Company Website - Environment Variables Example
# ─────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit real secrets to version control.
# ─────────────────────────────────────────────────────

# ── Database (PostgreSQL) ────────────────────────────
DOMAIN_HOST=
APP_IMAGE_TAG=cloud
POSTGRES_USER=postgres
POSTGRES_PASSWORD=rxza2cfem5b4mwcx
POSTGRES_DB=companywebsite
DATABASE_URL=postgresql://postgres:rxza2cfem5b4mwcx@enterprise-website-db-company-website-syj4x5:5432/companywebsite
SECRET_KEY=mu4ubzbfjejs2zcshri1omrcex6unikd2rlmbfreofoqcdx4hy3eynfngonnm64p

# ── Application ──────────────────────────────────────
DOMAIN_HOST=localhost
APP_IMAGE_TAG=cloud

# ── Logging ──────────────────────────────────────────
# Supported levels: debug, info, warn, error.
LOG_LEVEL=info
# Set to true only when diagnosing frontend HTTP requests.
HTTP_ACCESS_LOGS=false
# Set to true only when diagnosing API HTTP requests.
API_ACCESS_LOGS=false
# This project currently has no dedicated worker; keep false unless a future worker needs DB startup gating.
WORKER_WAIT_FOR_DB=false

# ── Redis (Optional) ───────────────────────────────────
# Redis is optional by default. Set REDIS_ENABLED=true to enable.
# Set REDIS_REQUIRED=true to make the app fail if Redis is unavailable.
# When disabled or unavailable, the app falls back to PostgreSQL + in-memory cache.
REDIS_ENABLED=false
REDIS_REQUIRED=false
REDIS_PASSWORD=change-me-to-a-random-redis-password
REDIS_URL=redis://default:${REDIS_PASSWORD}@redis:6379/0
REDIS_KEY_PREFIX=company-website:v1
REDIS_DEFAULT_TTL=300
REDIS_CONNECT_TIMEOUT=5
REDIS_READ_TIMEOUT=3
REDIS_WRITE_TIMEOUT=3
REDIS_MAX_RETRIES=3

# ── Migration Failure (Emergency Only) ─────────────
# Set to true only if you need to start the container despite failed migrations.
# Never enable this in production without manual verification.
ALLOW_MIGRATION_FAILURE=false

# ── Security ─────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret
