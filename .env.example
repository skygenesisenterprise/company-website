# ── Cloud / Dokploy configuration ───────────────────
DOMAIN_HOST=skygenesisenterprise.com
APP_IMAGE_TAG=cloud
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=companywebsite
DATABASE_URL=postgresql://postgres:change-me@postgresql:5432/companywebsite
SECRET_KEY=change-me

# ── Logging ──────────────────────────────────────────
# Supported levels: debug, info, warn, error.
LOG_LEVEL=info
# Set to true only when diagnosing frontend HTTP requests.
HTTP_ACCESS_LOGS=false
# Set to true only when diagnosing API HTTP requests.
API_ACCESS_LOGS=false
# This project currently has no dedicated worker; keep false unless a future worker needs DB startup gating.
WORKER_WAIT_FOR_DB=false
# `hold` keeps the container alive for `scripts/prisma-repair.sh inspect` and `prisma migrate resolve`.
MIGRATION_FAILURE_MODE=hold
# Only used when MIGRATION_FAILURE_MODE=exit.
MIGRATION_FAILURE_RESTART_DELAY=30

# ── Redis (Optional) ───────────────────────────────────
REDIS_ENABLED=true
REDIS_REQUIRED=true
REDIS_PASSWORD=change-me
REDIS_URL=redis://default:${REDIS_PASSWORD}@redis:6379/0
REDIS_KEY_PREFIX=company-website:v1
REDIS_DEFAULT_TTL=300
REDIS_CONNECT_TIMEOUT=5
REDIS_READ_TIMEOUT=3
REDIS_WRITE_TIMEOUT=3
REDIS_MAX_RETRIES=3
